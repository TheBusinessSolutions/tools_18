<odoo>

    <!-- Record rule: users can only see their own items -->
    <record id="command_center_item_user_rule" model="ir.rule">
        <field name="name">Command Center Item: User own items</field>
        <field name="model_id" ref="model_command_center_item"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

</odoo>
