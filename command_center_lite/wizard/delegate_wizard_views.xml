<odoo>

    <record id="view_command_center_delegate_wizard_form" model="ir.ui.view">
        <field name="name">command.center.delegate.wizard.form</field>
        <field name="model">command.center.delegate.wizard</field>
        <field name="arch" type="xml">
            <form string="Delegate Item">
                <group>
                    <field name="source_type" invisible="1"/>
                    <field name="source_id" invisible="1"/>
                    <field name="user_id" options="{'no_create': True}"/>
                </group>
                <footer>
                    <button name="action_delegate"
                            type="object"
                            string="Delegate"
                            class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
