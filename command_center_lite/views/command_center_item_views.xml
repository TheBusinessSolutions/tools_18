<odoo>

    <record id="view_command_center_item_kanban" model="ir.ui.view">
        <field name="name">command.center.item.kanban</field>
        <field name="model">command.center.item</field>
        <field name="arch" type="xml">
            <kanban default_group_by="priority_level"
                    default_order="priority_sequence, priority_score desc"
                    class="o_command_center_kanban"
                    records_draggable="0"
                    group_create="0"
                    group_delete="0"
                    group_edit="0"
                    quick_create="0"
                    sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="source_type"/>
                <field name="source_model"/>
                <field name="source_id"/>
                <field name="date_deadline"/>
                <field name="days_until_deadline"/>
                <field name="is_overdue"/>
                <field name="priority_score"/>
                <field name="priority_sequence"/>
                <field name="priority_level"/>
                <field name="user_id"/>
                <field name="partner_id"/>
                <field name="project_id"/>
                <field name="activity_type_id"/>
                <progressbar field="priority_level"
                            colors='{"1_critical": "danger", "2_high": "warning", "3_medium": "info", "4_low": "secondary"}'/>
                <templates>
                    <t t-name="card">
                        <main>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span t-attf-class="badge rounded-pill #{record.priority_level.raw_value == '1_critical' ? 'text-bg-danger' : record.priority_level.raw_value == '2_high' ? 'text-bg-warning' : record.priority_level.raw_value == '3_medium' ? 'text-bg-info' : 'text-bg-secondary'}">
                                    <t t-esc="record.priority_level.value"/>
                                </span>
                                <span t-if="record.source_type.raw_value == 'activity'" class="badge text-bg-purple" style="background-color: #8b5cf6 !important;">
                                    <i class="fa fa-clipboard me-1"/>Activity
                                </span>
                                <span t-elif="record.source_type.raw_value == 'task'" class="badge text-bg-success">
                                    <i class="fa fa-check me-1"/>Task
                                </span>
                            </div>

                            <field name="name" class="fw-bold"/>

                            <div class="text-muted small mt-1">
                                <div t-if="record.date_deadline.raw_value">
                                    <i class="fa fa-calendar-o me-1"/>
                                    <field name="date_deadline"/>
                                </div>
                                <div t-if="record.project_id.raw_value">
                                    <i class="fa fa-folder-open-o me-1"/>
                                    <field name="project_id"/>
                                </div>
                                <div t-if="record.partner_id.raw_value">
                                    <i class="fa fa-user me-1"/>
                                    <field name="partner_id"/>
                                </div>
                            </div>

                            <div t-if="record.is_overdue.raw_value" class="mt-2">
                                <span class="badge text-bg-danger">
                                    <i class="fa fa-exclamation-triangle me-1"/>Overdue
                                </span>
                            </div>

                            <footer class="pt-2 mt-2 border-top d-flex flex-wrap gap-1">
                                <button name="action_mark_done"
                                        type="object"
                                        class="btn btn-success btn-sm"
                                        title="Mark as Done">
                                    <i class="fa fa-check"/>
                                </button>
                                <button name="action_cancel"
                                        type="object"
                                        class="btn btn-danger btn-sm"
                                        title="Cancel">
                                    <i class="fa fa-times"/>
                                </button>
                                <button name="action_delegate"
                                        type="object"
                                        class="btn btn-warning btn-sm"
                                        title="Delegate">
                                    <i class="fa fa-share"/>
                                </button>
                                <button name="action_view_origin"
                                        type="object"
                                        class="btn btn-secondary btn-sm"
                                        title="View Original">
                                    <i class="fa fa-eye"/>
                                </button>
                                <button name="action_archive"
                                        type="object"
                                        class="btn btn-dark btn-sm"
                                        title="Archive"
                                        t-if="record.source_type.raw_value == 'task'">
                                    <i class="fa fa-archive"/>
                                </button>
                            </footer>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_command_center_item_list" model="ir.ui.view">
        <field name="name">command.center.item.list</field>
        <field name="model">command.center.item</field>
        <field name="arch" type="xml">
            <list string="Command Center Items"
                  multi_edit="1"
                  sample="1"
                  default_order="priority_score desc, date_deadline asc">
                <field name="name" string="Name"/>
                <field name="source_type" string="Type"
                       decoration-info="source_type == 'activity'"
                       decoration-success="source_type == 'task'"/>
                <field name="priority_level" string="Priority"
                       widget="badge"
                       decoration-danger="priority_level == '1_critical'"
                       decoration-warning="priority_level == '2_high'"
                       decoration-info="priority_level == '3_medium'"
                       decoration-muted="priority_level == '4_low'"/>
                <field name="date_deadline" string="Deadline"
                       decoration-danger="is_overdue == True"/>
                <field name="days_until_deadline" string="Days"
                       decoration-danger="days_until_deadline &lt; 0"
                       decoration-warning="days_until_deadline == 0 or days_until_deadline == 1"/>
                <field name="partner_id" string="Partner" optional="show"/>
                <field name="project_id" string="Project" optional="show"/>
                <field name="is_overdue" column_invisible="1"/>
                <button name="action_mark_done"
                        type="object"
                        icon="fa-check"
                        title="Done"
                        class="text-success"/>
                <button name="action_cancel"
                        type="object"
                        icon="fa-times"
                        title="Cancel"
                        class="text-danger"/>
                <button name="action_delegate"
                        type="object"
                        icon="fa-share"
                        title="Delegate"
                        class="text-warning"/>
                <button name="action_view_origin"
                        type="object"
                        icon="fa-external-link"
                        title="View"/>
                <button name="action_archive"
                        type="object"
                        icon="fa-archive"
                        title="Archive"
                        invisible="source_type != 'task'"/>
            </list>
        </field>
    </record>

    <record id="view_command_center_item_search" model="ir.ui.view">
        <field name="name">command.center.item.search</field>
        <field name="model">command.center.item</field>
        <field name="arch" type="xml">
            <search string="Search Items">
                <field name="name" string="Name"
                       filter_domain="[('name', 'ilike', self)]"/>
                <field name="partner_id" string="Partner"/>
                <field name="project_id" string="Project"/>
                <separator/>
                <filter name="filter_today"
                        string="Today"
                        domain="[('date_deadline', '=', context_today().strftime('%Y-%m-%d'))]"
                        help="Items due today"/>
                <filter name="filter_overdue"
                        string="Overdue"
                        domain="[('is_overdue', '=', True)]"
                        help="Items past deadline"/>
                <filter name="filter_this_week"
                        string="This Week"
                        domain="[
                            ('date_deadline', '>=', context_today().strftime('%Y-%m-%d')),
                            ('date_deadline', '&lt;=', (context_today() + relativedelta(days=7)).strftime('%Y-%m-%d'))
                        ]"
                        help="Items due this week"/>
                <filter name="filter_no_deadline"
                        string="No Deadline"
                        domain="[('date_deadline', '=', False)]"
                        help="Items without deadline"/>

                <separator/>

                <filter name="filter_critical"
                        string="Critical"
                        domain="[('priority_level', '=', '1_critical')]"/>
                <filter name="filter_high"
                        string="High Priority"
                        domain="[('priority_level', '=', '2_high')]"/>

                <separator/>

                <filter name="filter_activities"
                        string="Activities"
                        domain="[('source_type', '=', 'activity')]"
                        help="Only activities"/>
                <filter name="filter_tasks"
                        string="Tasks"
                        domain="[('source_type', '=', 'task')]"
                        help="Only project tasks"/>

                <separator/>

                <group expand="0" string="Group By">
                    <filter name="group_priority"
                            string="Priority"
                            context="{'group_by': 'priority_level'}"/>
                    <filter name="group_type"
                            string="Type"
                            context="{'group_by': 'source_type'}"/>
                    <filter name="group_deadline"
                            string="Deadline"
                            context="{'group_by': 'date_deadline:day'}"/>
                    <filter name="group_project"
                            string="Project"
                            context="{'group_by': 'project_id'}"/>
                    <filter name="group_partner"
                            string="Partner"
                            context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_command_center_item_form" model="ir.ui.view">
        <field name="name">command.center.item.form</field>
        <field name="model">command.center.item</field>
        <field name="arch" type="xml">
            <form string="Command Center Item" create="0" edit="0" delete="0">
                <header>
                    <button name="action_mark_done"
                            type="object"
                            string="Mark as Done"
                            class="btn-primary"/>
                    <button name="action_view_origin"
                            type="object"
                            string="View Original"
                            class="btn-secondary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Details">
                            <field name="source_type" readonly="1"/>
                            <field name="priority_level" readonly="1"
                                widget="badge"
                                decoration-danger="priority_level == '1_critical'"
                                decoration-warning="priority_level == '2_high'"
                                decoration-info="priority_level == '3_medium'"/>
                            <field name="priority_score" readonly="1"/>
                            <field name="date_deadline" readonly="1"/>
                            <field name="days_until_deadline" readonly="1"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                        <group string="References">
                            <field name="user_id" readonly="1"/>
                            <field name="partner_id" readonly="1"/>
                            <field name="project_id" readonly="1"/>
                            <field name="activity_type_id" readonly="1"
                                invisible="source_type != 'activity'"/>
                        </group>
                    </group>
                    <group string="Technical Information" groups="base.group_no_one">
                        <field name="source_model" readonly="1"/>
                        <field name="source_id" readonly="1"/>
                        <field name="date_create" readonly="1"/>
                    </group>
                    <notebook invisible="not summary">
                        <page string="Notes">
                            <field name="summary" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>
